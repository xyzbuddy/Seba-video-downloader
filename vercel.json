{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/diu-yt-downloader/dist/public",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://video-downloader-8drh.onrender.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}